#!/bin/bash
#/ Usage: bin/conductor-setup
#/
#/ Setup files that are not tracked in git for Conductor workspaces.
#/ This is run automatically when a new workspace is created.

set -e
cd $(dirname "$0")/..

if [ -z "$CONDUCTOR_WORKSPACE_PATH" ]; then
  echo "Error: CONDUCTOR_WORKSPACE_PATH is not set. Run this from Conductor."
  exit 1
fi

WORKSPACE_NAME=$(basename "$CONDUCTOR_WORKSPACE_PATH")

# Create .env with workspace-specific database names and host config.
echo "Creating .env for workspace: $WORKSPACE_NAME..."
cat > .env <<EOF
SHIPYRD_DATABASE_URL=mysql2://root:root@127.0.0.1:3306/shipyrd_${WORKSPACE_NAME}_primary
SHIPYRD_QUEUE_DATABASE_URL=mysql2://root:root@127.0.0.1:3306/shipyrd_${WORKSPACE_NAME}_queue
SHIPYRD_CABLE_DATABASE_URL=mysql2://root:root@127.0.0.1:3306/shipyrd_${WORKSPACE_NAME}_cable

PORT=\${CONDUCTOR_PORT}
SHIPYRD_HOST=localhost:\${CONDUCTOR_PORT}
SHIPYRD_HOOKS_HOST=localhost:\${CONDUCTOR_PORT}

COMMUNITY_EDITION=0
EOF

echo "Creating .env.test for workspace: $WORKSPACE_NAME..."
cat > .env.test <<EOF
SHIPYRD_DATABASE_URL=mysql2://root:root@127.0.0.1:3306/shipyrd_${WORKSPACE_NAME}_test
EOF

# Run full setup (dependencies, database, fixtures)
bin/setup

echo "Conductor setup complete!"
