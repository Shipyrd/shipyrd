<% label ||= nil %>
<% button_class ||= nil %>

<button class="button is-light clipboard <%= button_class %>" data-clipboard-target="<%= target %>">
  <span class="icon-text">
    <span class="icon">
      <i class="fa-solid fa-copy"></i>
    </span>
    <span>
      Copy <%= label %>
    </span>
  </span>
</button>
