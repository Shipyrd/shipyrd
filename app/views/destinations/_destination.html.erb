<%= turbo_stream_from destination %>

<% application = destination.application %>

<div id="<%= dom_id destination %>">
  <h2 class="mb-4 is-size-2 has-text-weight-medium">
    <%= link_to application.display_name, application_path(application) %>

    <%= destination_tag(destination) %>
  </h2>

  <div class="content">
    <p>
      <strong>URL:</strong>
      <% if destination.url.present? %>
        <%= link_to destination.url, destination.url, target: "_blank", class: "is-link" %>
      <% end %>
    </p>

    <p>
      <strong>Branch:</strong>
      <span class="tag"><%= destination.branch %></span>
    </p>
  </div>

  <%= link_to "Edit this destination", edit_application_destination_path(application, destination), class: "button is-primary my-4" %>

  <hr>

  <h3 class="is-size-3">Badges</h3>

  <div class="columns">
    <div class="column is-half">
      <h5 class="is-size-5 mb-2">Last deploy</h5>

      <p>
        <%= image_tag destination_deployed_badge(destination, :image), class: "mb-2" %>
      </p>

      <pre class="mb-1 is-sr-only"><code id="badge_deployed_markdown"><%= destination_deployed_badge(destination, :markdown) %></code></pre>
      <div id="badge_deployed_image" class="is-sr-only"><%= destination_deployed_badge(destination, :image) %></div>

        <%= render "shared/copy_to_clipboard", target: "#badge_deployed_markdown", label: "markdown", button_class: "is-small" %>
        <%= render "shared/copy_to_clipboard", target: "#badge_deployed_image", label: "image URL", button_class: "is-small" %>
    </div>

    <div class="column is-half">
      <h5 class="is-size-5 mb-2">Lock status</h5>

      <p>
        <%= image_tag destination_locked_badge(destination, :image), class: "mb-2" %>
      </p>

      <pre class="is-sr-only"><code id="badge_locked_markdown"><%= destination_locked_badge(destination, :markdown) %></code></pre>
      <div id="badge_locked_image" class="is-sr-only"><%= destination_locked_badge(destination, :image) %></div>

      <p class="mt-1">
        <%= render "shared/copy_to_clipboard", target: "#badge_locked_markdown", label: "markdown", button_class: "is-small" %>
        <%= render "shared/copy_to_clipboard", target: "#badge_locked_image", label: "image URL", button_class: "is-small" %>
      </p>
    </div>
  </div>

  <hr>

  <h3 class="is-size-3">Servers</h3>

  <% if destination.servers.empty? %>
    <p>No servers deployed to for this destination.</p>
  <% else %>
    <% destination.servers.each do |server| %>
      <%= render server %>
    <% end %>
  <% end %>
</div>
